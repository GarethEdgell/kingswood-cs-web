---
import { getServerSupabase, getProfile } from '../lib/supabase';
import { COURSES, getCoursesByCategory } from '../data/courses';

const pathname = Astro.url.pathname;

let user = null;
let isTeacher = false;
try {
  const supabase = getServerSupabase(Astro.request, Astro.cookies);
  const { data } = await supabase.auth.getUser();
  user = data.user ?? null;
  if (user) {
    const profile = await getProfile(user.id, supabase);
    isTeacher = profile?.role === 'teacher' || profile?.role === 'admin';
  }
} catch { /* not authenticated */ }

function isActive(href: string) {
  return pathname === href || (href !== '/' && pathname.startsWith(href));
}

const csCourses = getCoursesByCategory('Computer Science');
const dfCourses = getCoursesByCategory('Digital Futures');
---

<header class="sticky top-0 z-50 border-b border-white/8 bg-[var(--nav-bg)] backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-white">
      <div class="h-8 w-8 rounded-lg bg-gradient-to-br from-cyan-500 to-purple-600"></div>
      Kingswood CS
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-0.5 md:flex">
      <!-- Learning dropdown -->
      <li class="relative group">
        <button class={`rounded-md px-3 py-1.5 text-sm font-medium transition-colors flex items-center gap-1 ${isActive('/digital-futures') || isActive('/revision') ? 'bg-white/10 text-white' : 'text-slate-400 hover:bg-white/5 hover:text-white'}`}>
          Learning
          <svg class="w-3 h-3 opacity-60 transition-transform group-hover:rotate-180" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </button>
        <div class="absolute left-0 top-full mt-1 w-64 rounded-xl border border-white/10 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50 py-2" style="background:var(--bg-card)">
          <!-- Digital Futures -->
          <div class="px-3 py-2">
            <p class="text-xs font-bold uppercase tracking-wider text-cyan-400 mb-2">Digital Futures</p>
            {dfCourses.map(course => (
              <a href={course.href} class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm text-slate-300 hover:bg-white/8 hover:text-white transition-colors">
                <span>{course.icon}</span>
                <span>{course.name}</span>
              </a>
            ))}
          </div>

          <div class="my-1 border-t border-white/8"></div>

          <!-- Computer Science -->
          <div class="px-3 py-2">
            <p class="text-xs font-bold uppercase tracking-wider text-green-400 mb-2">Computer Science</p>
            {csCourses.map(course => (
              <a href={course.href} class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm text-slate-300 hover:bg-white/8 hover:text-white transition-colors">
                <span>{course.icon}</span>
                <span class="flex-1">{course.name}</span>
                {course.badge && <span class="rounded-full bg-white/8 px-1.5 py-0.5 text-xs text-slate-500">{course.badge}</span>}
              </a>
            ))}
          </div>

          <div class="my-1 border-t border-white/8"></div>

          <!-- Tools -->
          <a href="/tools" class="flex items-center gap-2.5 rounded-lg mx-1 px-3 py-2 text-sm text-slate-300 hover:bg-white/8 hover:text-white transition-colors">
            <span>⚙️</span>
            <span>Interactive Tools</span>
          </a>
        </div>
      </li>
    </ul>

    <!-- Auth buttons -->
    <div class="hidden items-center gap-2 md:flex">
      {user ? (
        <>
          {isTeacher && <a href="/teacher/digital-futures" class="rounded-md px-3 py-1.5 text-sm font-semibold text-cyan-400 hover:text-white">🏫 Teacher</a>}
          <a href="/dashboard" class="rounded-md px-3 py-1.5 text-sm font-medium text-slate-400 hover:text-white">Dashboard</a>
          <form method="POST" action="/auth/signout" style="display:inline;">
            <button type="submit" class="rounded-md border border-white/10 bg-white/5 px-4 py-1.5 text-sm font-semibold text-white hover:bg-white/10">Sign out</button>
          </form>
        </>
      ) : (
        <>
          <a href="/login" class="rounded-md px-3 py-1.5 text-sm font-medium text-slate-400 hover:text-white">Log in</a>
          <a href="/signup" class="rounded-2xl bg-gradient-to-r from-cyan-500 to-cyan-600 px-4 py-1.5 text-sm font-bold text-black hover:shadow-lg hover:shadow-cyan-500/50 transition-all">Sign up</a>
        </>
      )}
    </div>

    <!-- Mobile menu button -->
    <button class="md:hidden flex items-center gap-2 text-slate-400 hover:text-white">
      ☰
    </button>
  </nav>
</header>
