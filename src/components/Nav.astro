<style>
  /* Dropdown visibility is driven solely by the `.open` class on .nav-dropdown
     (toggled by JS). No CSS :hover controls visibility — that is what caused
     touch devices to see nothing, and mixing it with JS caused the double-click. */
  .nav-dropdown-panel {
    display: none;
  }
  .nav-dropdown.open > .nav-dropdown-panel {
    display: block;
  }
  .nav-dropdown.open > button .nav-chevron {
    transform: rotate(180deg);
  }

  /* ── Mobile (< md): the primary nav becomes a dropdown column ──────────── */
  @media (max-width: 767px) {
    #primaryNav.mobile-open {
      display: flex !important;
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0.125rem;
      padding: 0.5rem;
      max-height: 80vh;
      overflow-y: auto;
      background: var(--nav-bg, #050a14);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    #primaryNav.mobile-open .nav-dropdown { position: static; width: 100%; }
    /* On mobile the panel expands inline (accordion) rather than floating.
       A plain display toggle is used here — reliable, no transition timing or
       clipping quirks. */
    #primaryNav.mobile-open .nav-dropdown-panel {
      position: static;
      width: 100%;
      margin: 0;
      border: none;
      box-shadow: none;
      border-radius: 0;
      transform: none;
      opacity: 1;
      visibility: visible;
      display: none;
      max-height: none;
      padding: 0.25rem 0;
      pointer-events: auto;
    }
    #primaryNav.mobile-open .nav-dropdown.open > .nav-dropdown-panel {
      display: block;
    }
  }
</style>

<script is:inline>
  (function () {
    // ── Theme toggle ──────────────────────────────────────────────────────
    const themeBtn = document.getElementById('themeToggle');
    if (themeBtn) {
      const setIcon = () => {
        themeBtn.textContent = document.documentElement.classList.contains('light') ? '🌙' : '☀️';
      };
      setIcon();
      themeBtn.addEventListener('click', () => {
        const light = !document.documentElement.classList.contains('light');
        document.documentElement.classList.toggle('light', light);
        try { localStorage.setItem('theme', light ? 'light' : 'dark'); } catch (e) {}
        setIcon();
      });
    }

    // ── Dropdown menus ────────────────────────────────────────────────────
    const dropdowns = Array.from(document.querySelectorAll('.nav-dropdown'));
    // Hover-to-open is a desktop enhancement only. We use Pointer Events and
    // check pointerType === 'mouse', so a touch tap can NEVER trigger hover —
    // that is what previously caused the open-then-close "click twice" bug on
    // touchscreen laptops.
    const hoverCapable = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    function setOpen(dropdown, open) {
      dropdown.classList.toggle('open', open);
      const btn = dropdown.querySelector('[data-dropdown-toggle]');
      if (btn) btn.setAttribute('aria-expanded', String(open));
    }

    function closeAll(except) {
      dropdowns.forEach((d) => { if (d !== except) setOpen(d, false); });
    }

    dropdowns.forEach((dropdown) => {
      const btn = dropdown.querySelector('[data-dropdown-toggle]');
      if (!btn) return;

      // Click/tap toggles — single action on every device.
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation(); // stops the document handler closing it on the same click
        const willOpen = !dropdown.classList.contains('open');
        closeAll(dropdown);
        setOpen(dropdown, willOpen);
      });

      if (hoverCapable) {
        dropdown.addEventListener('pointerenter', (e) => {
          if (e.pointerType !== 'mouse') return;
          closeAll(dropdown);
          setOpen(dropdown, true);
        });
        dropdown.addEventListener('pointerleave', (e) => {
          if (e.pointerType !== 'mouse') return;
          setOpen(dropdown, false);
        });
      }
    });

    // Click anywhere outside closes any open dropdown.
    document.addEventListener('click', () => closeAll(null));
    // Escape closes everything.
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(null); });

    // ── Mobile hamburger ──────────────────────────────────────────────────
    const mobileToggle = document.getElementById('mobileToggle');
    const primaryNav = document.getElementById('primaryNav');
    if (mobileToggle && primaryNav) {
      mobileToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = !primaryNav.classList.contains('mobile-open');
        primaryNav.classList.toggle('mobile-open', open);
        mobileToggle.setAttribute('aria-expanded', String(open));
        if (!open) closeAll(null);
      });
      // Tapping outside the menu closes the whole mobile panel.
      document.addEventListener('click', (e) => {
        if (primaryNav.classList.contains('mobile-open') &&
            !primaryNav.contains(e.target) && e.target !== mobileToggle) {
          primaryNav.classList.remove('mobile-open');
          mobileToggle.setAttribute('aria-expanded', 'false');
          closeAll(null);
        }
      });
    }
  })();
</script>
