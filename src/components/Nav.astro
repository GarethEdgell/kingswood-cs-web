---
import { getUser, getProfile } from '../lib/supabase';
import { COURSES, getCoursesByCategory } from '../data/courses';

const pathname = Astro.url.pathname;

let user = null;
let isTeacher = false;
try {
  const { user: authUser, client } = await getUser(Astro.request, Astro.cookies);
  user = authUser ?? null;
  if (user) {
    const profile = await getProfile(user.id, client);
    isTeacher = profile?.role === 'teacher' || profile?.role === 'admin';
  }
} catch (err) {
  console.log('Nav auth check failed:', err);
}

function isActive(href: string) {
  return pathname === href || (href !== '/' && pathname.startsWith(href));
}

const csCourses = getCoursesByCategory('Computer Science');
const dfCourses = getCoursesByCategory('Digital Futures');
