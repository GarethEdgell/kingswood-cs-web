---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Terms of Use — Kingswood Computer Science"
  description="Terms and conditions for using this platform."
>
  <Nav />

  <section class="px-4 py-24 sm:px-6 sm:py-32">
    <div class="mx-auto max-w-3xl prose prose-invert">
      <h1 class="text-4xl font-black text-white">Terms of Use</h1>
      <p class="text-slate-400">Last updated: June 2026</p>

      <h2 class="text-2xl font-bold text-white mt-8">Who Can Use This Site</h2>
      <p class="text-slate-300">
        This site is for Kingswood School students, teachers, and staff only. You must have a valid school Microsoft account.
      </p>

      <h2 class="text-2xl font-bold text-white mt-8">Acceptable Use</h2>
      <p class="text-slate-300">
        You agree to use this site for educational purposes only. No hacking, spam, abuse, or circumventing security controls.
      </p>

      <h2 class="text-2xl font-bold text-white mt-8">Content</h2>
      <p class="text-slate-300">
        All educational content is provided as-is for learning. While we work to ensure accuracy, we accept no liability for errors.
      </p>

      <h2 class="text-2xl font-bold text-white mt-8">Account Security</h2>
      <p class="text-slate-300">
        You are responsible for keeping your Microsoft account secure. Do not share your password.
      </p>

      <h2 class="text-2xl font-bold text-white mt-8">Questions?</h2>
      <p class="text-slate-300">
        Ask your teacher about any concerns regarding these terms.
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>
