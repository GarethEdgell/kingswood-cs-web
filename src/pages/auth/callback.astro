---
// Supabase OAuth callback handler
// Vercel env vars ensure this stays secure

const code = Astro.url.searchParams.get('code');
const error = Astro.url.searchParams.get('error');

if (error) {
  return Astro.redirect(`/login?error=${error}`);
}

if (!code) {
  return Astro.redirect('/login?error=no_code');
}

// In a real app, the Supabase client handles this redirect automatically.
// This page is here for reference; most OAuth flows handle the callback in the browser.
---

<html>
  <head>
    <title>Authenticating...</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body style="background: #050a14; color: #e2e8f0; font-family: system-ui; display: flex; align-items: center; justify-content: center; min-height: 100vh;">
    <div style="text-align: center;">
      <h1>Authenticating...</h1>
      <p>Please wait while we sign you in.</p>
      <script>
        // Auto-redirect to dashboard after auth completes
        setTimeout(() => {
          window.location.href = '/dashboard';
        }, 2000);
      </script>
    </div>
  </body>
</html>
