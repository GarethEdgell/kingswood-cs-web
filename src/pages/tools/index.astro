---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Interactive CS Tools — Kingswood Computer Science"
  description="Free interactive Computer Science tools. Binary converter, logic gates, algorithm visualiser, LMC, FSM, trace tables and more."
>
  <Nav />

  <section class="px-4 pt-16 pb-6 sm:px-6 sm:pt-20">
    <div class="mx-auto max-w-5xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-cyan-400">Interactive Tools</p>
      <h1 class="mt-2 text-4xl font-extrabold text-white sm:text-5xl">CS Revision Tools</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-400">
        Interactive tools for the most visual and calculation-heavy parts of GCSE and A Level Computer Science.
      </p>
    </div>
  </section>

  <section class="px-4 pb-16 sm:px-6">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

        <a href="/tools/cartoon-challenges" class="group relative rounded-xl border border-pink-400/30 bg-white/5 p-6 transition-all hover:border-pink-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-pink-400/20 border border-pink-400/30 px-2.5 py-0.5 text-xs text-pink-400 font-semibold">New 🎉</span></div>
          <div class="mb-3 text-3xl">🎮</div>
          <h3 class="font-semibold text-white group-hover:text-pink-400 transition-colors">Cartoon Challenges</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Fun tap-to-play puzzles: be the sorting algorithm, guide a maze robot, light up logic gates and unscramble algorithms.</p>
          <span class="mt-3 inline-block text-sm font-medium text-pink-400">Play now →</span>
        </a>

        <a href="/tools/data-representation" class="group relative rounded-xl border border-green-400/30 bg-white/5 p-6 transition-all hover:border-green-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-green-400/20 border border-green-400/30 px-2.5 py-0.5 text-xs text-green-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">🔢</div>
          <h3 class="font-semibold text-white group-hover:text-green-400 transition-colors">Data Representation</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Binary/hex/denary converter, two's complement, bit shifts, file size calculator and ASCII table.</p>
          <span class="mt-3 inline-block text-sm font-medium text-green-400">Open tool →</span>
        </a>

        <a href="/tools/logic-gates" class="group relative rounded-xl border border-amber-400/30 bg-white/5 p-6 transition-all hover:border-amber-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-amber-400/20 border border-amber-400/30 px-2.5 py-0.5 text-xs text-amber-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">⚡</div>
          <h3 class="font-semibold text-white group-hover:text-amber-400 transition-colors">Logic Gate Simulator</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Toggle inputs and see outputs live. AND, OR, NOT, NAND, NOR, XOR, XNOR — with truth tables.</p>
          <span class="mt-3 inline-block text-sm font-medium text-amber-400">Open tool →</span>
        </a>

        <a href="/tools/algorithms" class="group relative rounded-xl border border-cyan-400/30 bg-white/5 p-6 transition-all hover:border-cyan-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-cyan-400/20 border border-cyan-400/30 px-2.5 py-0.5 text-xs text-cyan-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">🔃</div>
          <h3 class="font-semibold text-white group-hover:text-cyan-400 transition-colors">Algorithm Visualiser</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Bubble sort, insertion sort, merge sort, linear search, binary search — animated step-by-step.</p>
          <span class="mt-3 inline-block text-sm font-medium text-cyan-400">Open tool →</span>
        </a>

        <a href="/tools/trace-table" class="group relative rounded-xl border border-green-400/30 bg-white/5 p-6 transition-all hover:border-green-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-green-400/20 border border-green-400/30 px-2.5 py-0.5 text-xs text-green-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">📋</div>
          <h3 class="font-semibold text-white group-hover:text-green-400 transition-colors">Trace Table Builder</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Complete trace tables for pseudocode programs. Check your answers against worked solutions.</p>
          <span class="mt-3 inline-block text-sm font-medium text-green-400">Open tool →</span>
        </a>

        <a href="/tools/lmc" class="group relative rounded-xl border border-purple-400/30 bg-white/5 p-6 transition-all hover:border-purple-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-purple-400/20 border border-purple-400/30 px-2.5 py-0.5 text-xs text-purple-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">🤖</div>
          <h3 class="font-semibold text-white group-hover:text-purple-400 transition-colors">LMC Simulator</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Little Man Computer simulator. Write LMC assembly, step through execution and watch all 100 mailboxes.</p>
          <span class="mt-3 inline-block text-sm font-medium text-purple-400">Open tool →</span>
        </a>

        <a href="/tools/fsm" class="group relative rounded-xl border border-cyan-400/30 bg-white/5 p-6 transition-all hover:border-cyan-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-cyan-400/20 border border-cyan-400/30 px-2.5 py-0.5 text-xs text-cyan-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">🔄</div>
          <h3 class="font-semibold text-white group-hover:text-cyan-400 transition-colors">FSM Simulator</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Build finite state machines, add states and transitions, then test strings step-by-step.</p>
          <span class="mt-3 inline-block text-sm font-medium text-cyan-400">Open tool →</span>
        </a>

        <a href="/tools/turing" class="group relative rounded-xl border border-purple-400/30 bg-white/5 p-6 transition-all hover:border-purple-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-purple-400/20 border border-purple-400/30 px-2.5 py-0.5 text-xs text-purple-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">📼</div>
          <h3 class="font-semibold text-white group-hover:text-purple-400 transition-colors">Turing Machine Simulator</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Define states and a transition function, load an input tape and step through execution.</p>
          <span class="mt-3 inline-block text-sm font-medium text-purple-400">Open tool →</span>
        </a>

        <a href="/tools/exam-countdown" class="group relative rounded-xl border border-purple-400/30 bg-white/5 p-6 transition-all hover:border-purple-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-purple-400/20 border border-purple-400/30 px-2.5 py-0.5 text-xs text-purple-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">⏱️</div>
          <h3 class="font-semibold text-white group-hover:text-purple-400 transition-colors">Exam Countdown</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Days until your Computer Science exam — OCR GCSE and A Level — with revision timeline advice.</p>
          <span class="mt-3 inline-block text-sm font-medium text-purple-400">Open tool →</span>
        </a>

        <a href="/revision/flashcards" class="group relative rounded-xl border border-green-400/30 bg-white/5 p-6 transition-all hover:border-green-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-green-400/20 border border-green-400/30 px-2.5 py-0.5 text-xs text-green-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">🃏</div>
          <h3 class="font-semibold text-white group-hover:text-green-400 transition-colors">Flashcards</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Drill key terminology for OCR GCSE and A Level. Flip cards, track progress and focus on weak areas.</p>
          <span class="mt-3 inline-block text-sm font-medium text-green-400">Open flashcards →</span>
        </a>

        <a href="/revision/notes" class="group relative rounded-xl border border-cyan-400/30 bg-white/5 p-6 transition-all hover:border-cyan-400/60 hover:bg-white/8">
          <div class="absolute -top-2.5 right-4"><span class="rounded-full bg-cyan-400/20 border border-cyan-400/30 px-2.5 py-0.5 text-xs text-cyan-400 font-semibold">Live ✓</span></div>
          <div class="mb-3 text-3xl">📚</div>
          <h3 class="font-semibold text-white group-hover:text-cyan-400 transition-colors">Revision Notes</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">Structured notes for every OCR spec point. Key terms, worked examples, exam tips and common mistakes.</p>
          <span class="mt-3 inline-block text-sm font-medium text-cyan-400">Open notes →</span>
        </a>

      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
