---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const tools = [
  { name: 'Binary & Hex Converter', href: '/tools/data-representation', emoji: '🔢' },
  { name: 'Logic Gates Simulator', href: '/tools/logic-gates', emoji: '⚡' },
  { name: 'Algorithms Visualizer', href: '/tools/algorithms', emoji: '📊' },
  { name: 'Trace Table Builder', href: '/tools/trace-table', emoji: '📋' },
  { name: 'LMC Simulator', href: '/tools/lmc', emoji: '⚙️' },
  { name: 'FSM Builder', href: '/tools/fsm', emoji: '🔄' },
];
---

<BaseLayout
  title="Interactive Tools — Computer Science Learning"
  description="Free interactive tools for binary, logic gates, algorithms, LMC and more."
>
  <Nav />

  <section class="px-4 py-24 sm:px-6 sm:py-32">
    <div class="mx-auto max-w-6xl">
      <h1 class="text-5xl sm:text-6xl font-black text-white mb-4">Interactive Tools</h1>
      <p class="text-lg text-slate-400 mb-12 max-w-2xl">Learn by doing. Explore algorithms, binary, logic gates and more with hands-on simulators.</p>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {tools.map(tool => (
          <a href={tool.href} class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 hover:border-white/20 transition-colors">
            <div class="text-4xl mb-3">{tool.emoji}</div>
            <h3 class="font-bold text-white">{tool.name}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
