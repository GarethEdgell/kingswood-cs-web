---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import TraceTable from '../../components/tools/TraceTable.svelte';
---

<BaseLayout
  title="Trace Table Builder — GCSE & A Level CS Exam Technique | CompSci Tutoring"
  description="Practice trace tables for GCSE and A Level Computer Science. Fill in variable values row by row and check your answers. Worked examples included."
>
  <Nav />

  <section class="border-b border-white/8 bg-[var(--bg-card)] px-4 py-6 sm:px-6">
    <div class="mx-auto max-w-7xl flex flex-wrap items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <a href="/tools" class="text-slate-500 hover:text-white transition-colors text-sm">← Tools</a>
        <span class="text-slate-700">/</span>
        <span class="text-sm text-slate-300">📋 Trace Table</span>
      </div>
    </div>
  </section>

  <section class="px-4 py-10 sm:px-6">
    <div class="mx-auto max-w-5xl">
      <div class="mb-6">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-3xl">📋</span>
          <h1 class="text-2xl font-extrabold text-white">Trace Table Builder</h1>
        </div>
        <p class="text-slate-400">
          Choose a program, fill in the variable values row by row, then check your answers. Use "Custom" to trace your own code.
        </p>
      </div>

      <TraceTable client:load />
    </div>
  </section>

  <Footer />
</BaseLayout>
