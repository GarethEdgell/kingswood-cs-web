---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getUser, getProfile, restSelect } from '../lib/supabase';
import { COURSES } from '../data/courses';

const { user, client: supabase } = await getUser(Astro.request, Astro.cookies);

if (!user) {
  return Astro.redirect('/login');
}

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const profile = await getProfile(user.id, supabase, accessToken);

// Redirect teachers to their dashboard
if (profile?.role === 'teacher' || profile?.role === 'admin') {
  return Astro.redirect('/teacher/digital-futures');
}

const displayName = profile?.full_name || user.email?.split('@')[0] || 'Student';

const accessibleCourses = COURSES;
const dfCourses = accessibleCourses.filter(c => c.category === 'Digital Futures');
const csCourses = accessibleCourses.filter(c => c.category === 'Computer Science');

// My assignments — from the classes this student is enrolled in.
const myClasses = await restSelect('class_students', `student_id=eq.${user.id}&select=class_id`, accessToken);
const myClassIds = myClasses.map((c: any) => c.class_id);
const myAssignments = myClassIds.length
  ? await restSelect('assignments', `class_id=in.(${myClassIds.join(',')})&select=id,type,title,due_date&order=created_at.desc`, accessToken)
  : [];
const myAssignmentIds = myAssignments.map((a: any) => a.id);
const mySubs = myAssignmentIds.length
  ? await restSelect('submissions', `assignment_id=in.(${myAssignmentIds.join(',')})&student_id=eq.${user.id}&select=assignment_id,score,ai_status`, accessToken)
  : [];
const subByAssignment: Record<string, any> = {};
for (const s of mySubs) subByAssignment[s.assignment_id] = s;
---

<BaseLayout
  title="Dashboard — Your Progress"
  description="Track your Digital Futures lessons and revision progress."
>
  <Nav />

  <section class="px-4 py-24 sm:px-6 sm:py-32">
    <div class="mx-auto max-w-6xl">
      <h1 class="text-5xl font-black text-white mb-4">Welcome back, {displayName}</h1>
      <p class="text-lg text-slate-400 mb-12">Your accessible courses and progress</p>

      <!-- Quick Stats -->
      <div class="grid gap-6 sm:grid-cols-3 mb-12">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-center">
          <div class="text-4xl font-black text-cyan-400 mb-2">0</div>
          <p class="text-slate-400 text-sm">Lessons Completed</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-center">
          <div class="text-4xl font-black text-purple-400 mb-2">0%</div>
          <p class="text-slate-400 text-sm">Overall Progress</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-center">
          <div class="text-4xl font-black text-green-400 mb-2">{accessibleCourses.length}</div>
          <p class="text-slate-400 text-sm">Courses Available</p>
        </div>
      </div>

      <!-- My Assignments -->
      {myAssignments.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-black text-white mb-6 flex items-center gap-2">📌 My Assignments</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {myAssignments.map((a: any) => {
              const sub = subByAssignment[a.id];
              return (
                <a href={`/digital-futures/assignment/${a.id}`}
                   class="rounded-2xl border border-white/10 bg-white/5 p-5 hover:bg-white/10 hover:border-cyan-500/40 transition-all">
                  <div class="flex items-center justify-between mb-2">
                    <span class="rounded-full px-2.5 py-0.5 text-xs font-bold bg-purple-500/20 text-purple-300 border border-purple-500/30 capitalize">
                      {a.type === 'ai-task' ? 'AI Task' : a.type}
                    </span>
                    {a.type === 'quiz' && sub?.score != null && (
                      <span class="text-xs font-bold text-green-400">{sub.score}%</span>
                    )}
                    {a.type === 'ai-task' && sub?.ai_status === 'done' && (
                      <span class="text-xs font-bold text-green-400">AI ready</span>
                    )}
                    {a.type === 'ai-task' && (sub?.ai_status === 'pending' || sub?.ai_status === 'processing') && (
                      <span class="text-xs font-bold text-amber-400">Waiting for teacher</span>
                    )}
                    {!sub && <span class="text-xs font-bold text-cyan-400">Not started</span>}
                  </div>
                  <h3 class="font-bold text-white">{a.title}</h3>
                  {a.due_date && <p class="text-xs text-slate-500 mt-1">Due: {new Date(a.due_date).toLocaleDateString()}</p>}
                </a>
              );
            })}
          </div>
        </div>
      )}

      <!-- Digital Futures -->
      {dfCourses.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-black text-white mb-6 flex items-center gap-2">
            ✨ Digital Futures
          </h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {dfCourses.map(course => (
              <a href={course.href}
                 class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 hover:border-white/20 transition-all">
                <div class="text-3xl mb-3">{course.icon}</div>
                <h3 class="font-bold text-white mb-1">{course.name}</h3>
                <p class="text-sm text-slate-400">{course.description}</p>
                <div class="mt-4 text-cyan-400 text-sm font-semibold">Start learning →</div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Computer Science -->
      {csCourses.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-black text-white mb-6 flex items-center gap-2">
            📚 Computer Science Revision
          </h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {csCourses.map(course => (
              <a href={course.href}
                 class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 hover:border-white/20 transition-all">
                <div class="text-3xl mb-3">{course.icon}</div>
                <h3 class="font-bold text-white mb-1">{course.name}</h3>
                <p class="text-sm text-slate-400">{course.description}</p>
                <div class="flex items-center gap-2 mt-4 text-sm text-slate-400">
                  {course.badge && <span class="bg-white/10 px-2 py-1 rounded text-xs">{course.badge}</span>}
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {accessibleCourses.length === 0 && (
        <div class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center">
          <p class="text-slate-400 mb-4">You don't have access to any courses yet.</p>
          <p class="text-sm text-slate-500">Ask your teacher to give you access to Digital Futures or Computer Science revision.</p>
        </div>
      )}

      <!-- Quick Links -->
      <div class="mt-16 border-t border-white/8 pt-12">
        <h2 class="text-2xl font-black text-white mb-6">Tools</h2>
        <a href="/tools" class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 transition-colors inline-block">
          <div class="text-3xl mb-2">⚙️</div>
          <h3 class="font-bold text-white">Interactive Tools</h3>
          <p class="text-sm text-slate-400 mt-1">Binary, logic gates, algorithms, LMC, FSM</p>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
