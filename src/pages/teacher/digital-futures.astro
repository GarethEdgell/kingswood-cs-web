---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getUser } from '../../lib/supabase';

const { user } = await getUser(Astro.request, Astro.cookies);

if (!user) {
  return Astro.redirect('/login');
}
---

<BaseLayout
  title="Teacher Dashboard — Digital Futures Management"
  description="Manage your Digital Futures classes, view student progress, and track assignments."
>
  <Nav />

  <section class="px-4 py-24 sm:px-6 sm:py-32">
    <div class="mx-auto max-w-6xl">
      <h1 class="text-5xl font-black text-white mb-4">🏫 Teacher Dashboard</h1>
      <p class="text-lg text-slate-400 mb-12">Manage your Digital Futures classes</p>

      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
          <h3 class="font-bold text-white text-lg mb-4">📋 My Classes</h3>
          <p class="text-slate-400 mb-4">No classes yet</p>
          <button class="rounded-lg bg-cyan-500/20 border border-cyan-500/50 text-cyan-400 hover:bg-cyan-500/30 px-4 py-2 text-sm font-semibold">
            + Create New Class
          </button>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
          <h3 class="font-bold text-white text-lg mb-4">📊 Class Statistics</h3>
          <p class="text-slate-400">0 students | 0 lessons assigned</p>
        </div>
      </div>

      <div class="mt-12 border-t border-white/8 pt-12">
        <h2 class="text-2xl font-black text-white mb-6">Resources</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <a href="/digital-futures" class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 transition-colors">
            <div class="text-3xl mb-2">✨</div>
            <h3 class="font-bold text-white">Digital Futures Curriculum</h3>
            <p class="text-sm text-slate-400 mt-1">View all 34 lessons</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
