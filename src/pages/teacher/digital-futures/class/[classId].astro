---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Nav from '../../../../components/Nav.astro';
import Footer from '../../../../components/Footer.astro';
import ReportGenerator from '../../../../components/teacher/ReportGenerator.svelte';
import AssignmentCreator from '../../../../components/teacher/AssignmentCreator.svelte';
import { getUser, getProfile, restSelect } from '../../../../lib/supabase';
import { getAllDFLessons } from '../../../../data/digitalFutures';
import { hasQuiz } from '../../../../data/dfQuizzes';

const { user } = await getUser(Astro.request, Astro.cookies);

if (!user) return Astro.redirect('/login');

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const profile = await getProfile(user.id, null, accessToken);
if (profile?.role !== 'teacher' && profile?.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { classId } = Astro.params;

// Fetch class details
const classRows = await restSelect(
  'classes',
  `id=eq.${classId}&teacher_id=eq.${user.id}&select=id,name,code,year_group,description&limit=1`,
  accessToken
);
const cls = classRows[0];

if (!cls) return Astro.redirect('/teacher/digital-futures');

// Fetch students in class
const classStudents = await restSelect('class_students', `class_id=eq.${classId}&select=student_id`, accessToken);
const studentIds = classStudents.map((cs: any) => cs.student_id);

// Fetch profiles for those students
const profiles = studentIds.length > 0
  ? await restSelect('profiles', `id=in.(${studentIds.join(',')})&select=id,full_name,email`, accessToken)
  : [];
const profileById: Record<string, any> = {};
for (const p of profiles) profileById[p.id] = p;

const students = studentIds.map((id: string) => ({
  id,
  name: profileById[id]?.full_name || profileById[id]?.email || 'Unknown',
}));

// Fetch progress for all students
const progressRecords = studentIds.length > 0
  ? await restSelect('student_progress', `student_id=in.(${studentIds.join(',')})&select=*`, accessToken)
  : [];

const avgScore = progressRecords.length
  ? Math.round(progressRecords.reduce((sum: number, p: any) => sum + (p.avg_quiz_score ?? 0), 0) / progressRecords.length)
  : null;

const totalLessons = progressRecords.length
  ? Math.round(progressRecords.reduce((sum: number, p: any) => sum + (p.lessons_completed ?? 0), 0) / progressRecords.length)
  : 0;

// Assignments for this class + submission counts.
const classAssignments = await restSelect(
  'assignments',
  `class_id=eq.${classId}&select=id,type,title,due_date,created_at&order=created_at.desc`,
  accessToken
);
const assignmentIds = classAssignments.map((a: any) => a.id);
const allSubs = assignmentIds.length
  ? await restSelect('submissions', `assignment_id=in.(${assignmentIds.join(',')})&select=assignment_id,ai_status`, accessToken)
  : [];
const subCount: Record<string, number> = {};
const pendingCount: Record<string, number> = {};
for (const s of allSubs) {
  subCount[s.assignment_id] = (subCount[s.assignment_id] ?? 0) + 1;
  if (s.ai_status === 'pending') pendingCount[s.assignment_id] = (pendingCount[s.assignment_id] ?? 0) + 1;
}

// Lesson list for the assignment creator (filtered to this class's year group).
const lessonOptions = getAllDFLessons()
  .filter(l => !cls.year_group || l.year === cls.year_group)
  .map(l => ({ id: l.id, title: l.title, year: l.year, hasQuiz: hasQuiz(l.id) }));
---

<BaseLayout
  title={`${cls.name} — Teacher Dashboard`}
  description="Manage your Digital Futures class and track student progress."
>
  <Nav />

  <section class="px-4 py-12 sm:px-6 border-b border-white/8">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-center gap-2 text-sm text-slate-400 mb-4">
        <a href="/teacher/digital-futures" class="hover:text-white transition-colors">Teacher Dashboard</a>
        <span>›</span>
        <span class="text-white">{cls.name}</span>
      </div>
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="text-4xl font-black text-white mb-2">{cls.name}</h1>
          <p class="text-slate-400">{cls.description ?? 'Digital Futures'} · Year {cls.year_group}</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-center">
          <div class="text-xs text-slate-400 mb-1">Class Code</div>
          <div class="text-xl font-black text-cyan-400 font-mono">{cls.code}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-10 sm:px-6">
    <div class="mx-auto max-w-6xl space-y-10">

      <!-- Stats -->
      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-center">
          <div class="text-4xl font-black text-cyan-400 mb-1">{students.length}</div>
          <p class="text-slate-400 text-sm">Students</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-center">
          <div class="text-4xl font-black text-purple-400 mb-1">{totalLessons}</div>
          <p class="text-slate-400 text-sm">Avg Lessons Completed</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-center">
          <div class="text-4xl font-black text-green-400 mb-1">{avgScore !== null ? `${avgScore}%` : '—'}</div>
          <p class="text-slate-400 text-sm">Class Average Score</p>
        </div>
      </div>

      <!-- Students -->
      <div>
        <h2 class="text-2xl font-black text-white mb-4">Students</h2>
        {students.length === 0 ? (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center text-slate-400">
            No students enrolled yet. Share the class code <span class="text-cyan-400 font-bold font-mono">{cls.code}</span> with your students.
          </div>
        ) : (
          <div class="rounded-2xl border border-white/10 bg-white/5 overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/10">
                  <th class="text-left px-4 py-3 text-slate-400 font-semibold">Student</th>
                  <th class="text-center px-4 py-3 text-slate-400 font-semibold">Lessons</th>
                  <th class="text-center px-4 py-3 text-slate-400 font-semibold">Avg Score</th>
                </tr>
              </thead>
              <tbody>
                {students.map((s: any) => {
                  const prog = (progressRecords ?? []).find((p: any) => p.student_id === s.id && p.course_id === 'digital-futures');
                  return (
                    <tr class="border-b border-white/5 hover:bg-white/3 transition-colors">
                      <td class="px-4 py-3 text-white font-medium">{s.name}</td>
                      <td class="px-4 py-3 text-center text-slate-300">{prog?.lessons_completed ?? 0}</td>
                      <td class="px-4 py-3 text-center">
                        {prog?.avg_quiz_score != null ? (
                          <span class={`font-bold ${prog.avg_quiz_score >= 75 ? 'text-green-400' : prog.avg_quiz_score >= 50 ? 'text-amber-400' : 'text-red-400'}`}>
                            {Math.round(prog.avg_quiz_score)}%
                          </span>
                        ) : (
                          <span class="text-slate-500">—</span>
                        )}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>

      <!-- Assignments -->
      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-black text-white">Assignments</h2>
          <AssignmentCreator client:load classId={classId!} lessons={lessonOptions} />
        </div>

        {classAssignments.length === 0 ? (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center text-slate-400">
            No assignments yet. Create a quiz or an AI task with the button above.
          </div>
        ) : (
          <div class="grid gap-3 sm:grid-cols-2">
            {classAssignments.map((a: any) => (
              <a href={`/teacher/digital-futures/assignment/${a.id}`}
                 class="rounded-2xl border border-white/10 bg-white/5 p-5 hover:border-cyan-500/40 hover:bg-white/8 transition-all">
                <div class="flex items-center justify-between mb-2">
                  <span class="rounded-full px-2.5 py-0.5 text-xs font-bold bg-purple-500/20 text-purple-300 border border-purple-500/30 capitalize">
                    {a.type === 'ai-task' ? 'AI Task' : a.type}
                  </span>
                  {(pendingCount[a.id] ?? 0) > 0 && (
                    <span class="text-xs font-bold text-amber-400">{pendingCount[a.id]} pending AI</span>
                  )}
                </div>
                <h3 class="font-bold text-white mb-1">{a.title}</h3>
                <p class="text-xs text-slate-400">{subCount[a.id] ?? 0} submission{(subCount[a.id] ?? 0) === 1 ? '' : 's'}</p>
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- Report Generator -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
        <ReportGenerator
          client:load
          classId={classId!}
          className={cls.name}
          studentCount={students.length}
        />
      </div>

      <!-- Quick Actions -->
      <div>
        <h2 class="text-2xl font-black text-white mb-4">Quick Actions</h2>
        <div class="grid gap-3 sm:grid-cols-3">
          <a href={`/teacher/digital-futures/class/${classId}/students`}
             class="rounded-xl bg-cyan-500/20 border border-cyan-500/30 text-cyan-400 hover:bg-cyan-500/30 px-5 py-3 font-semibold transition-colors text-center">
            📚 Manage Course Access
          </a>
          <a href={`/teacher/digital-futures/stats/${classId}`}
             class="rounded-xl bg-green-500/20 border border-green-500/30 text-green-400 hover:bg-green-500/30 px-5 py-3 font-semibold transition-colors text-center">
            📊 Detailed Statistics
          </a>
          <a href="/teacher/digital-futures"
             class="rounded-xl bg-white/5 border border-white/10 text-slate-400 hover:bg-white/10 hover:text-white px-5 py-3 font-semibold transition-colors text-center">
            ← All Classes
          </a>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</BaseLayout>
