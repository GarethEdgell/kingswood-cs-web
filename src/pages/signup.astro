---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Sign Up — Kingswood Computer Science"
  description="Create an account with your school email."
>
  <Nav />

  <section class="px-4 py-24 sm:px-6 sm:py-32">
    <div class="mx-auto max-w-md">
      <h1 class="text-4xl font-black text-white mb-8 text-center">Sign Up</h1>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
        <form id="signupForm" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-semibold text-slate-300 mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2 text-white placeholder-slate-500 focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50"
              placeholder="name@student.kingswood.edu"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-semibold text-slate-300 mb-2">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="8"
              class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2 text-white placeholder-slate-500 focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50"
              placeholder="At least 8 characters"
            />
          </div>

          <button
            type="submit"
            class="w-full rounded-xl bg-gradient-to-r from-cyan-500 to-cyan-600 text-black font-bold py-3 hover:shadow-lg hover:shadow-cyan-500/50 transition-all"
          >
            Create Account
          </button>

          <div id="error" class="text-red-400 text-sm text-center hidden"></div>
        </form>

        <div class="mt-6 pt-6 border-t border-white/8 text-center">
          <p class="text-slate-400 text-sm">Already have an account?</p>
          <a href="/login" class="text-cyan-400 hover:text-cyan-300 font-semibold">Log in →</a>
        </div>
      </div>

      <p class="text-slate-500 text-sm text-center mt-6">
        Your account will be created and you can log in immediately.
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('signupForm') as HTMLFormElement;
  const errorDiv = document.getElementById('error') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    try {
      const { error } = await supabase.auth.signUp({
        email,
        password,
        options: {
          emailRedirectTo: `${location.origin}/auth/callback`,
        },
      });

      if (error) {
        errorDiv.textContent = error.message;
        errorDiv.classList.remove('hidden');
        return;
      }

      // Show success message
      errorDiv.classList.remove('hidden');
      errorDiv.classList.add('text-green-400');
      errorDiv.textContent = 'Account created! Redirecting to login...';

      // Redirect to login after 2 seconds
      setTimeout(() => {
        window.location.href = '/login';
      }, 2000);
    } catch (err) {
      errorDiv.textContent = 'An error occurred. Please try again.';
      errorDiv.classList.remove('hidden');
    }
  });
</script>
