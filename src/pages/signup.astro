---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Sign Up — Kingswood Computer Science"
  description="Create an account with your Microsoft school email."
>
  <Nav />

  <section class="px-4 py-24 sm:px-6 sm:py-32">
    <div class="mx-auto max-w-md">
      <h1 class="text-4xl font-black text-white mb-8 text-center">Sign Up</h1>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
        <p class="text-slate-300 mb-6 text-center">Create an account to track your progress through Digital Futures and revision materials</p>

        <button class="w-full rounded-xl bg-gradient-to-r from-cyan-500 to-cyan-600 text-black font-bold py-3 hover:shadow-lg hover:shadow-cyan-500/50 transition-all flex items-center justify-center gap-2">
          🔐 Sign up with Microsoft
        </button>

        <div class="mt-6 pt-6 border-t border-white/8 text-center">
          <p class="text-slate-400 text-sm">Already have an account?</p>
          <a href="/login" class="text-cyan-400 hover:text-cyan-300 font-semibold">Log in →</a>
        </div>
      </div>

      <p class="text-slate-500 text-sm text-center mt-6">
        You must use your official Kingswood school Microsoft account to sign up.
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>
