---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { DF_BRAND, getDFUnitsByYear } from '../../data/digitalFutures';

const y8Units = getDFUnitsByYear(8);
const y9Units = getDFUnitsByYear(9);

const highlights = [
  { emoji: '🤖', title: 'AI-First Learning', desc: 'Use real AI tools in every unit — Microsoft Copilot, not just theory' },
  { emoji: '🎨', title: 'Create Real Things', desc: 'Design presentations, automate workflows, and build with Power Apps' },
  { emoji: '🏢', title: 'Enterprise Tools', desc: 'Master Microsoft 365 — the platform used by 400+ million professionals' },
  { emoji: '🌍', title: 'Future Ready', desc: 'Skills that employers, universities and the world actually need' },
];
---

<BaseLayout
  title="Digital Futures — AI & Digital Skills | Kingswood"
  description="Master AI and digital skills with Digital Futures — Year 8 and 9 curriculum using Microsoft 365 tools."
>
  <Nav />

  <section class="relative overflow-hidden px-4 py-24 sm:px-6 sm:py-32 text-center">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 left-1/2 -translate-x-1/2 h-[600px] w-[800px] rounded-full opacity-20"
           style="background: radial-gradient(circle, #00d4ff 0%, #7c3aed 50%, transparent 70%)"></div>
    </div>

    <div class="relative mx-auto max-w-4xl">
      <div class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-semibold mb-6"
           style="border-color:rgba(0,212,255,0.4); background:rgba(0,212,255,0.08); color:#00d4ff">
        <span class="h-1.5 w-1.5 rounded-full animate-pulse" style="background:#00d4ff"></span>
        Now live for Years 8–11
      </div>

      <h1 class="text-6xl sm:text-7xl font-black text-white mb-4 leading-none">
        Digital<br/>
        <span style="background: linear-gradient(135deg, #00d4ff, #7c3aed); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Futures
        </span>
      </h1>

      <p class="text-lg sm:text-xl text-slate-400 mb-6 max-w-2xl mx-auto leading-relaxed">
        {DF_BRAND.tagline}
      </p>

      <div class="flex flex-wrap justify-center gap-3">
        <a href="/digital-futures/year-8"
           class="rounded-2xl px-6 py-3 text-sm font-bold text-white transition-all hover:scale-105 hover:shadow-lg hover:shadow-cyan-500/30"
           style="background: linear-gradient(135deg, #00d4ff, #0099bb)">
          Year 8 Curriculum →
        </a>
        <a href="/digital-futures/year-9"
           class="rounded-2xl px-6 py-3 text-sm font-bold text-white transition-all hover:scale-105 hover:shadow-lg hover:shadow-purple-500/30"
           style="background: linear-gradient(135deg, #7c3aed, #5b21b6)">
          Year 9 Curriculum →
        </a>
        <a href="/digital-futures/ai-course"
           class="rounded-2xl px-6 py-3 text-sm font-bold text-white transition-all hover:scale-105 hover:shadow-lg hover:shadow-green-500/30"
           style="background: linear-gradient(135deg, #00ff94, #00b36b)">
          Year 10 & 11 AI Course →
        </a>
      </div>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6 border-t border-white/8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center mb-10">
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-3">Why Digital Futures?</h2>
        <p class="text-slate-400 max-w-xl mx-auto">The digital skills curriculum for your generation.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {highlights.map(h => (
          <div class="rounded-2xl border border-white/8 bg-[var(--bg-card)] p-6 hover:border-white/15 transition-colors">
            <div class="text-4xl mb-3">{h.emoji}</div>
            <h3 class="font-bold text-white text-sm mb-1">{h.title}</h3>
            <p class="text-xs text-slate-500 leading-relaxed">{h.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="year8" class="px-4 py-16 sm:px-6 border-t border-white/8 scroll-mt-20">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-center gap-4 mb-8">
        <div class="rounded-2xl px-4 py-2 text-sm font-black"
             style="background:rgba(0,212,255,0.15); color:#00d4ff; border:1px solid rgba(0,212,255,0.3)">
          Year 8
        </div>
        <div>
          <h2 class="text-2xl font-black text-white">Foundations</h2>
          <p class="text-slate-400 text-sm">Core digital skills and AI basics</p>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {y8Units.flatMap(unit => unit.lessons).map((lesson) => (
          <a href={`/digital-futures/lesson/${lesson.id}`} class="rounded-xl border border-white/8 bg-[var(--bg-card)] p-4 hover:border-white/15 transition-colors hover:bg-white/8 cursor-pointer group">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl group-hover:scale-110 transition-transform">{lesson.emoji}</span>
              <span class="text-xs font-bold" style={`color:${lesson.colour}`}>Lesson {lesson.lessonNum}</span>
            </div>
            <div class="font-bold text-white text-sm group-hover:text-cyan-400 transition-colors">{lesson.title}</div>
            <div class="text-xs text-slate-500 mt-1">{lesson.subtitle}</div>
            <div class="mt-3 inline-block rounded-lg px-3 py-1.5 text-xs font-bold border transition-all"
                 style={`border-color:${lesson.colour}40; background:${lesson.colour}15; color:${lesson.colour}`}>
              📖 View Lesson
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="year9" class="px-4 py-16 sm:px-6 border-t border-white/8 scroll-mt-20">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-center gap-4 mb-8">
        <div class="rounded-2xl px-4 py-2 text-sm font-black"
             style="background:rgba(124,58,237,0.15); color:#a78bfa; border:1px solid rgba(124,58,237,0.3)">
          Year 9
        </div>
        <div>
          <h2 class="text-2xl font-black text-white">Advanced</h2>
          <p class="text-slate-400 text-sm">AI, data visualization and creation</p>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {y9Units.flatMap(unit => unit.lessons).map((lesson) => (
          <a href={`/digital-futures/lesson/${lesson.id}`} class="rounded-xl border border-white/8 bg-[var(--bg-card)] p-4 hover:border-white/15 transition-colors hover:bg-white/8 cursor-pointer group">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl group-hover:scale-110 transition-transform">{lesson.emoji}</span>
              <span class="text-xs font-bold" style={`color:${lesson.colour}`}>Lesson {lesson.lessonNum}</span>
            </div>
            <div class="font-bold text-white text-sm group-hover:text-cyan-400 transition-colors">{lesson.title}</div>
            <div class="text-xs text-slate-500 mt-1">{lesson.subtitle}</div>
            <div class="mt-3 inline-block rounded-lg px-3 py-1.5 text-xs font-bold border transition-all"
                 style={`border-color:${lesson.colour}40; background:${lesson.colour}15; color:${lesson.colour}`}>
              📖 View Lesson
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="year1011" class="px-4 py-16 sm:px-6 border-t border-white/8 scroll-mt-20">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-center gap-4 mb-6">
        <div class="rounded-2xl px-4 py-2 text-sm font-black"
             style="background:rgba(0,255,148,0.15); color:#00ff94; border:1px solid rgba(0,255,148,0.3)">
          Year 10 & 11
        </div>
        <div>
          <h2 class="text-2xl font-black text-white">AI Course · Self-Guided</h2>
          <p class="text-slate-400 text-sm">No lesson time? No problem. Complete it independently and earn badges.</p>
        </div>
      </div>

      <a href="/digital-futures/ai-course" class="block rounded-2xl border-2 p-6 transition-all hover:scale-[1.01]"
         style="border-color:rgba(0,255,148,0.3); background:rgba(0,255,148,0.06)">
        <div class="grid gap-6 sm:grid-cols-2 items-center">
          <div>
            <div class="text-4xl mb-3">🤖</div>
            <h3 class="text-xl font-black text-white mb-2">Digital Futures &amp; AI</h3>
            <p class="text-slate-300 text-sm leading-relaxed mb-3">
              14 bite-sized, hands-on modules across two tracks — use AI brilliantly and honestly,
              stay safe online, and get ready for the future of work. Go at your own pace, earn a badge
              for each module and a certificate for each track.
            </p>
            <span class="inline-block rounded-lg px-4 py-2 text-sm font-bold text-white"
                  style="background: linear-gradient(135deg, #00ff94, #00b36b)">Start the course →</span>
          </div>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div class="rounded-lg border border-white/10 bg-white/5 p-3"><div class="text-lg mb-1">🧠</div><div class="font-bold text-white">Year 10: AI Foundations</div><div class="text-slate-500 mt-0.5">Understand &amp; use AI well</div></div>
            <div class="rounded-lg border border-white/10 bg-white/5 p-3"><div class="text-lg mb-1">🚀</div><div class="font-bold text-white">Year 11: AI &amp; Your Future</div><div class="text-slate-500 mt-0.5">Apply it, stay honest, get ahead</div></div>
            <div class="rounded-lg border border-white/10 bg-white/5 p-3"><div class="text-lg mb-1">💬</div><div class="font-bold text-white">Prompting · Study skills</div><div class="text-slate-500 mt-0.5">Spotting fakes · Safety</div></div>
            <div class="rounded-lg border border-white/10 bg-white/5 p-3"><div class="text-lg mb-1">⚖️</div><div class="font-bold text-white">Ethics · Careers</div><div class="text-slate-500 mt-0.5">Capstone build</div></div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .animate-pulse { animation: pulse 2s ease-in-out infinite; }
</style>
