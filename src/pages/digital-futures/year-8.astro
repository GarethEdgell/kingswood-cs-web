---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getDFUnitsByYear } from '../../data/digitalFutures';

const units = getDFUnitsByYear(8);
const lessons = units.flatMap(u => u.lessons);
---

<BaseLayout
  title="Year 8 Digital Futures — AI & Digital Skills | Kingswood"
  description="Year 8 Digital Futures curriculum — 17 lessons covering digital foundations, AI basics and Microsoft 365 tools."
>
  <Nav />

  <section class="px-4 py-12 sm:px-6 border-b border-white/8">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-center gap-3 mb-4 text-sm text-slate-400">
        <a href="/digital-futures" class="hover:text-white transition-colors">Digital Futures</a>
        <span>›</span>
        <span class="text-white">Year 8</span>
      </div>
      <div class="flex items-start gap-4">
        <div class="rounded-2xl px-4 py-2 text-sm font-black shrink-0"
             style="background:rgba(0,212,255,0.15); color:#00d4ff; border:1px solid rgba(0,212,255,0.3)">
          Year 8
        </div>
        <div>
          <h1 class="text-4xl font-black text-white mb-2">Digital Foundations</h1>
          <p class="text-slate-400">Core digital skills, AI literacy and Microsoft 365 — {lessons.length} lessons</p>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-10 sm:px-6">
    <div class="mx-auto max-w-6xl">
      {units.map(unit => (
        <div class="mb-12">
          <div class="flex items-center gap-3 mb-5">
            <span class="text-2xl">{unit.emoji}</span>
            <div>
              <h2 class="text-xl font-black text-white">{unit.title}</h2>
              <p class="text-slate-400 text-sm">{unit.subtitle}</p>
            </div>
          </div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {unit.lessons.map(lesson => (
              <a href={`/digital-futures/lesson/${lesson.id}`}
                 class="rounded-xl border border-white/8 bg-[var(--bg-card)] p-4 hover:border-cyan-500/40 hover:bg-white/8 transition-all group">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-2xl group-hover:scale-110 transition-transform">{lesson.emoji}</span>
                  <span class="text-xs font-bold" style={`color:${lesson.colour}`}>Lesson {lesson.lessonNum}</span>
                </div>
                <div class="font-bold text-white text-sm group-hover:text-cyan-400 transition-colors">{lesson.title}</div>
                <div class="text-xs text-slate-500 mt-1">{lesson.subtitle}</div>
                <div class="mt-3 inline-block rounded-lg px-3 py-1.5 text-xs font-bold border transition-all"
                     style={`border-color:${lesson.colour}40; background:${lesson.colour}15; color:${lesson.colour}`}>
                  📖 View Lesson
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}

      <div class="flex gap-4 pt-8 border-t border-white/8">
        <a href="/digital-futures" class="rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-slate-300 hover:text-white hover:bg-white/10 transition-colors">
          ← All Years
        </a>
        <a href="/digital-futures/year-9" class="rounded-xl px-5 py-3 text-sm font-bold text-white hover:opacity-90 transition-colors"
           style="background:linear-gradient(135deg,#7c3aed,#5b21b6)">
          Year 9 Curriculum →
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
