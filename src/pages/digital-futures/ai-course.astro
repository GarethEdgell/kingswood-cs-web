---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SelfGuidedCourse from '../../components/SelfGuidedCourse.svelte';
import { getAllAIModules } from '../../data/digitalFuturesAI';

const moduleCount = getAllAIModules().length;
---

<BaseLayout
  title="Digital Futures & AI — Year 10 & 11 Self-Guided Course | Kingswood"
  description="A fun, self-guided Digital Futures and AI course for Year 10 and 11: prompt engineering, AI study skills, spotting fakes, online safety, AI ethics, careers and a build-your-own capstone. Work through it at your own pace and earn badges."
>
  <Nav />

  <section class="relative overflow-hidden px-4 py-16 sm:px-6 sm:py-20 text-center">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 left-1/2 -translate-x-1/2 h-[520px] w-[760px] rounded-full opacity-20"
           style="background: radial-gradient(circle, #00d4ff 0%, #7c3aed 50%, transparent 70%)"></div>
    </div>
    <div class="relative mx-auto max-w-3xl">
      <div class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-semibold mb-6"
           style="border-color:rgba(0,212,255,0.4); background:rgba(0,212,255,0.08); color:#00d4ff">
        <span class="h-1.5 w-1.5 rounded-full animate-pulse" style="background:#00d4ff"></span>
        Year 10 & 11 · Self-guided · No sign-up needed
      </div>
      <h1 class="text-4xl sm:text-6xl font-black text-white mb-4 leading-tight">
        Digital Futures <span style="background:linear-gradient(135deg,#00d4ff,#7c3aed);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">& AI</span>
      </h1>
      <p class="text-lg text-slate-400 mb-6 max-w-2xl mx-auto">
        No lessons, no pressure — just {moduleCount} bite-sized modules you can complete whenever you like.
        Learn to use AI brilliantly and honestly, stay safe online, and get ready for the future of work.
        Earn a badge for each one and a certificate for each track.
      </p>
      <div class="flex flex-wrap justify-center gap-3 text-sm">
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">🎮 Earn badges</span>
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">🖐️ Hands-on missions</span>
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">⏱️ Go at your pace</span>
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">💾 Saves automatically</span>
      </div>
    </div>
  </section>

  <section class="px-4 pb-6 sm:px-6">
    <div class="mx-auto max-w-3xl">
      <div class="rounded-xl border border-cyan-500/25 bg-cyan-500/5 p-4 text-sm text-slate-300 leading-relaxed">
        <strong class="text-white">How it works:</strong> pick any module, read the key ideas, then do the
        <strong>mission</strong> — a real, hands-on task. Tick it off to earn the badge. Your progress and notes
        save on this device automatically. Use AI tools responsibly and always follow your school's rules on
        honest use. 🤝
      </div>
    </div>
  </section>

  <section class="px-4 pb-16 sm:px-6">
    <SelfGuidedCourse client:load />
  </section>

  <Footer />
</BaseLayout>

<style>
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
  .animate-pulse { animation: pulse 2s ease-in-out infinite; }
</style>
