---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import Quiz from '../../../components/Quiz.svelte';
import { getAllDFLessons } from '../../../data/digitalFutures';
import { getQuizForLesson } from '../../../data/dfQuizzes';

export const prerender = true;

export async function getStaticPaths() {
  const allLessons = getAllDFLessons();
  return allLessons.map(lesson => ({
    params: { id: lesson.id }
  }));
}

const { id } = Astro.params;

const allLessons = getAllDFLessons();
const lesson = allLessons.find(l => l.id === id);

if (!lesson) {
  return Astro.redirect('/digital-futures');
}

const quiz = getQuizForLesson(lesson.id);
---

<BaseLayout
  title={`Quiz: ${lesson.title} — Digital Futures`}
  description={`Test your knowledge on ${lesson.title}`}
>
  <Nav />

  <section class="px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-2xl">
      <div class="flex items-center gap-3 mb-6">
        <a href={`/digital-futures/lesson/${lesson.id}`} class="text-slate-400 hover:text-white transition-colors">← Back to Lesson</a>
      </div>

      <div class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-4xl">{lesson.emoji}</span>
          <div>
            <h1 class="text-3xl font-black text-white">Quiz: {lesson.title}</h1>
            <p class="text-slate-400">{lesson.subtitle}</p>
          </div>
        </div>
        <p class="text-sm text-slate-500">Practice mode — answer at your own pace. Your teacher may also set this quiz as an assignment.</p>
      </div>

      {quiz ? (
        <Quiz client:load quiz={quiz} />
      ) : (
        <div class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center">
          <div class="text-5xl mb-4">📝</div>
          <h2 class="text-xl font-bold text-white mb-2">No quiz yet for this lesson</h2>
          <p class="text-slate-400 mb-6">Use the objectives below to self-check your understanding.</p>
          <ul class="space-y-3 text-left">
            {lesson.objectives.map((obj, i) => (
              <li class="flex gap-3">
                <span class="text-cyan-400 font-bold min-w-fit">Q{i + 1}.</span>
                <span class="text-slate-300">Can you explain: {obj.toLowerCase()}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>
