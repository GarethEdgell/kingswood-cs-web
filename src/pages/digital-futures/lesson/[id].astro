---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { getAllDFLessons, DF_UNITS } from '../../../data/digitalFutures';

export const prerender = true;

export async function getStaticPaths() {
  const allLessons = getAllDFLessons();
  return allLessons.map(lesson => ({
    params: { id: lesson.id }
  }));
}

const { id } = Astro.params;

// Get all lessons and find the one matching the ID
const allLessons = getAllDFLessons();
const lesson = allLessons.find(l => l.id === id);

if (!lesson) {
  return Astro.redirect('/digital-futures');
}

// Get the unit for this lesson
const unit = DF_UNITS.find(u => u.lessons.some(l => l.id === id));
---

<BaseLayout
  title={`${lesson.title} — Digital Futures`}
  description={lesson.subtitle}
>
  <Nav />

  <section class="px-4 py-12 sm:px-6 border-b border-white/8">
    <div class="mx-auto max-w-4xl">
      <div class="flex items-center gap-3 mb-4">
        <a href="/digital-futures" class="text-slate-400 hover:text-white transition-colors">← Back to Curriculum</a>
      </div>

      <div class="flex items-start gap-4 mb-6">
        <div class="text-5xl">{lesson.emoji}</div>
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="rounded-full px-3 py-1 text-xs font-bold" style={`background:${lesson.colour}20; color:${lesson.colour}; border:1px solid ${lesson.colour}40`}>
              Year {lesson.year} • Lesson {lesson.lessonNum}
            </span>
          </div>
          <h1 class="text-5xl font-black text-white mb-2">{lesson.title}</h1>
          <p class="text-xl text-slate-400">{lesson.subtitle}</p>
        </div>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-6 mb-8">
        <p class="text-lg text-white italic">{lesson.bigIdea}</p>
      </div>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-4xl">
      <div class="grid gap-8">
        <!-- Learning Objectives -->
        <div>
          <h2 class="text-2xl font-black text-white mb-4">🎯 Learning Objectives</h2>
          <ul class="space-y-3">
            {lesson.objectives.map(obj => (
              <li class="flex gap-3">
                <span class="text-cyan-400 font-bold min-w-fit">✓</span>
                <span class="text-slate-300">{obj}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Vocabulary -->
        {lesson.vocab.length > 0 && (
          <div>
            <h2 class="text-2xl font-black text-white mb-4">📚 Key Vocabulary</h2>
            <div class="grid gap-3 sm:grid-cols-2">
              {lesson.vocab.map(v => (
                <div class="rounded-xl border border-white/10 bg-white/5 p-4">
                  <div class="font-bold text-white mb-1">{v.term}</div>
                  <div class="text-sm text-slate-400">{v.def}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Lesson Timing -->
        <div>
          <h2 class="text-2xl font-black text-white mb-4">⏱️ Lesson Timing (50 mins)</h2>

          <div class="space-y-4">
            <!-- Hook -->
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <div class="flex items-start gap-3 mb-2">
                <span class="text-xl">🪝</span>
                <div>
                  <div class="font-bold text-white">Hook</div>
                  <div class="text-xs text-slate-400">{lesson.timing.hook.mins} mins</div>
                </div>
              </div>
              <p class="text-slate-300 ml-8">{lesson.timing.hook.activity}</p>
            </div>

            <!-- Teach -->
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <div class="flex items-start gap-3 mb-3">
                <span class="text-xl">👨‍🏫</span>
                <div>
                  <div class="font-bold text-white">Teach</div>
                  <div class="text-xs text-slate-400">{lesson.timing.teach.mins} mins</div>
                </div>
              </div>
              <ul class="space-y-2 ml-8">
                {lesson.timing.teach.points.map(point => (
                  <li class="text-slate-300 flex gap-2">
                    <span class="text-cyan-400">•</span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Create -->
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <div class="flex items-start gap-3 mb-2">
                <span class="text-xl">🛠️</span>
                <div>
                  <div class="font-bold text-white">Create</div>
                  <div class="text-xs text-slate-400">{lesson.timing.create.mins} mins</div>
                </div>
              </div>
              <p class="text-slate-300 ml-8 mb-3">{lesson.timing.create.task}</p>
              {lesson.timing.create.tools.length > 0 && (
                <div class="ml-8">
                  <div class="text-xs font-bold text-slate-400 mb-2">Tools:</div>
                  <div class="flex flex-wrap gap-2">
                    {lesson.timing.create.tools.map(tool => (
                      <span class="rounded-full px-3 py-1 text-xs bg-purple-500/20 text-purple-300 border border-purple-500/30">
                        {tool}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </div>

            <!-- Share -->
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <div class="flex items-start gap-3 mb-2">
                <span class="text-xl">📢</span>
                <div>
                  <div class="font-bold text-white">Share</div>
                  <div class="text-xs text-slate-400">{lesson.timing.share.mins} mins</div>
                </div>
              </div>
              <p class="text-slate-300 ml-8">{lesson.timing.share.activity}</p>
            </div>
          </div>
        </div>

        <!-- Tools Required -->
        {lesson.tools.length > 0 && (
          <div>
            <h2 class="text-2xl font-black text-white mb-4">🔧 Tools & Resources</h2>
            <div class="grid gap-3 sm:grid-cols-2">
              {lesson.tools.map(tool => (
                <a href={tool.url} target="_blank" rel="noopener noreferrer" class="rounded-xl border border-white/10 bg-white/5 p-4 hover:border-white/20 hover:bg-white/8 transition-all">
                  <div class="font-bold text-white mb-1">{tool.name}</div>
                  <div class="text-xs text-slate-400 mb-2">{tool.free ? '✅ Free' : '💰 Paid'}</div>
                  <div class="text-xs text-cyan-400 truncate">{tool.url}</div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- AI Angle -->
        <div>
          <h2 class="text-2xl font-black text-white mb-4">🤖 AI Angle</h2>
          <div class="rounded-xl border border-white/10 bg-white/5 p-6">
            <p class="text-slate-300">{lesson.aiAngle}</p>
          </div>
        </div>

        <!-- Evidence & Homework -->
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <h3 class="text-xl font-bold text-white mb-3">📝 Evidence of Learning</h3>
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <p class="text-slate-300">{lesson.evidence}</p>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-white mb-3">📚 Homework</h3>
            <div class="rounded-xl border border-white/10 bg-white/5 p-4">
              <p class="text-slate-300 mb-2">{lesson.homework.task}</p>
              <div class="text-xs text-slate-400">⏱️ {lesson.homework.mins} mins</div>
            </div>
          </div>
        </div>

        <!-- Differentiation -->
        <div>
          <h2 class="text-2xl font-black text-white mb-4">♿ Differentiation</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-xl border border-green-500/30 bg-green-500/10 p-4">
              <div class="font-bold text-green-400 mb-2">Support (for students who need help)</div>
              <p class="text-slate-300 text-sm">{lesson.differentiation.support}</p>
            </div>
            <div class="rounded-xl border border-yellow-500/30 bg-yellow-500/10 p-4">
              <div class="font-bold text-yellow-400 mb-2">Extension (for advanced learners)</div>
              <p class="text-slate-300 text-sm">{lesson.differentiation.extension}</p>
            </div>
          </div>
        </div>

        <!-- Teacher Note -->
        {lesson.teacherNote && (
          <div>
            <h2 class="text-2xl font-black text-white mb-4">👨‍🏫 Teacher Notes</h2>
            <div class="rounded-xl border-l-4 border-l-orange-500 border border-orange-500/20 bg-orange-500/10 p-4">
              <p class="text-slate-300">{lesson.teacherNote}</p>
            </div>
          </div>
        )}

        <!-- Navigation -->
        <div class="flex gap-4 pt-8 border-t border-white/8">
          <a href="/digital-futures" class="rounded-lg px-4 py-2 text-sm font-bold border border-white/20 text-white hover:bg-white/10 transition-colors">
            ← Back to All Lessons
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

