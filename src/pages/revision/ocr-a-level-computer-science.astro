---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { SPECS } from '../../data/specs';

const alevelTopics = (SPECS as any)['OCR'].topics;
---

<BaseLayout
  title="OCR A Level Computer Science (H446) — Revision Hub"
  description="500+ OCR A Level H446 Computer Science practice questions with detailed notes."
>
  <Nav />

  <section class="px-4 py-24 sm:px-6 sm:py-32">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12">
        <div class="text-xs font-bold text-purple-400 mb-2 uppercase tracking-wider">OCR H446</div>
        <h1 class="text-5xl sm:text-6xl font-black text-white mb-4">A Level Computer Science</h1>
        <p class="text-xl text-slate-400">Click a topic to access practice questions and revision notes</p>
      </div>

      <div class="mb-4">
        <h2 class="text-lg font-bold text-slate-400 mb-4">Component 01 — Computer Systems</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {alevelTopics.filter((t: any) => parseInt(t.id.split('-')[1]) <= 5).map((topic: any) => (
            <a href={`/revision/ocr-alevel/${topic.id}`}
               class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-purple-500/10 hover:border-purple-500/30 transition-all group">
              <div class="text-xs font-bold text-purple-400 mb-1">Topic {topic.num}</div>
              <h3 class="font-bold text-white group-hover:text-purple-400 transition-colors">{topic.name}</h3>
              <p class="text-sm text-slate-400 mt-2">📝 {topic.qCount} questions</p>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-8">
        <h2 class="text-lg font-bold text-slate-400 mb-4">Component 02 — Algorithms & Programming</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {alevelTopics.filter((t: any) => parseInt(t.id.split('-')[1]) > 5).map((topic: any) => (
            <a href={`/revision/ocr-alevel/${topic.id}`}
               class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-purple-500/10 hover:border-purple-500/30 transition-all group">
              <div class="text-xs font-bold text-purple-400 mb-1">Topic {topic.num}</div>
              <h3 class="font-bold text-white group-hover:text-purple-400 transition-colors">{topic.name}</h3>
              <p class="text-sm text-slate-400 mt-2">📝 {topic.qCount} questions</p>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 border-t border-white/8 pt-12">
        <h2 class="text-2xl font-black text-white mb-6">Revision Tools</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          <a href="/revision/flashcards" class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 transition-colors">
            <div class="text-3xl mb-2">🃏</div>
            <h3 class="font-bold text-white">Flashcards</h3>
            <p class="text-sm text-slate-400 mt-1">Test and drill key terminology</p>
          </a>
          <a href="/tools" class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 transition-colors">
            <div class="text-3xl mb-2">⚙️</div>
            <h3 class="font-bold text-white">Interactive Tools</h3>
            <p class="text-sm text-slate-400 mt-1">Binary, logic gates, algorithms, FSM</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
