---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { SPECS } from '../../data/specs';

const gcseTopics = (SPECS as any)['OCR GCSE'].topics;
---

<BaseLayout
  title="OCR GCSE Computer Science (J277) — Revision Hub"
  description="1000+ OCR GCSE J277 Computer Science practice questions with notes and flashcards."
>
  <Nav />

  <section class="px-4 py-24 sm:px-6 sm:py-32">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12">
        <div class="text-xs font-bold text-cyan-400 mb-2 uppercase tracking-wider">OCR J277</div>
        <h1 class="text-5xl sm:text-6xl font-black text-white mb-4">GCSE Computer Science</h1>
        <p class="text-xl text-slate-400">Click a topic to access practice questions and revision notes</p>
      </div>

      <div class="mb-4">
        <h2 class="text-lg font-bold text-slate-400 mb-4">Component 01 — Computer Systems</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {gcseTopics.filter((t: any) => t.id.startsWith('ocrg-') && parseInt(t.id.split('-')[1]) <= 6).map((topic: any) => (
            <a href={`/revision/ocr-gcse/${topic.id}`}
               class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-cyan-500/10 hover:border-cyan-500/30 transition-all group">
              <div class="text-xs font-bold text-cyan-400 mb-1">Topic {topic.num}</div>
              <h3 class="font-bold text-white group-hover:text-cyan-400 transition-colors">{topic.name}</h3>
              <p class="text-sm text-slate-400 mt-2">📝 {topic.qCount} questions</p>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-8">
        <h2 class="text-lg font-bold text-slate-400 mb-4">Component 02 — Computational Thinking</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {gcseTopics.filter((t: any) => t.id.startsWith('ocrg-') && parseInt(t.id.split('-')[1]) > 6).map((topic: any) => (
            <a href={`/revision/ocr-gcse/${topic.id}`}
               class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-cyan-500/10 hover:border-cyan-500/30 transition-all group">
              <div class="text-xs font-bold text-cyan-400 mb-1">Topic {topic.num}</div>
              <h3 class="font-bold text-white group-hover:text-cyan-400 transition-colors">{topic.name}</h3>
              <p class="text-sm text-slate-400 mt-2">📝 {topic.qCount} questions</p>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 border-t border-white/8 pt-12">
        <h2 class="text-2xl font-black text-white mb-6">Revision Tools</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          <a href="/revision/flashcards" class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 transition-colors">
            <div class="text-3xl mb-2">🃏</div>
            <h3 class="font-bold text-white">Flashcards</h3>
            <p class="text-sm text-slate-400 mt-1">Test and drill key terminology</p>
          </a>
          <a href="/tools" class="rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 transition-colors">
            <div class="text-3xl mb-2">⚙️</div>
            <h3 class="font-bold text-white">Interactive Tools</h3>
            <p class="text-sm text-slate-400 mt-1">Binary, logic gates, algorithms, LMC</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
