---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Flashcards from '../../components/revision/Flashcards.svelte';
---

<BaseLayout
  title="Computer Science Flashcards — GCSE & A Level | CompSci Tutoring"
  description="Computer Science flashcard decks for GCSE and A Level revision. Key terms, definitions, and concepts for AQA, OCR, and Cambridge specifications."
>
  <Nav />

  <section class="border-b border-white/8 bg-[var(--bg-card)] px-4 py-8 sm:px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h1 class="text-2xl font-bold text-white">Flashcards</h1>
          <p class="mt-1 text-sm text-slate-400">Key terms and definitions — click to flip, rate yourself, and track progress</p>
        </div>
        <div class="flex items-center gap-3">
          <a href="/revision" class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-300 hover:text-white transition-colors">
            ❓ Questions
          </a>
          <a href="/revision/notes" class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-300 hover:text-white transition-colors">
            📝 Notes
          </a>
        </div>
      </div>
    </div>
  </section>

  <Flashcards client:load />

  <Footer />
</BaseLayout>
