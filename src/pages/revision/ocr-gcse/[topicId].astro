---
export const prerender = true;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import QuizTopic from '../../../components/revision/QuizTopic.svelte';
import { SPECS } from '../../../data/specs';
import { QUESTIONS } from '../../../data/questions';
import { GCSE_NOTES } from '../../../data/notes-gcse';

export async function getStaticPaths() {
  const topics = (SPECS as any)['OCR GCSE'].topics;
  return topics.map((t: any) => ({ params: { topicId: t.id } }));
}

const { topicId } = Astro.params;
const topics = (SPECS as any)['OCR GCSE'].topics;
const topic = topics.find((t: any) => t.id === topicId);

if (!topic) return Astro.redirect('/revision/ocr-gcse-computer-science');

const questions = (QUESTIONS as any)[topicId] ?? [];

// Find OCR GCSE notes for this topic
const ocrGcseBoard = (GCSE_NOTES as any[]).find((b: any) => b.id === 'ocrgcse' || b.name?.includes('OCR'));
const topicNotes = ocrGcseBoard?.topics?.find((t: any) => t.id === topicId) ?? null;

// Get prev/next topics
const topicIndex = topics.findIndex((t: any) => t.id === topicId);
const prevTopic = topicIndex > 0 ? topics[topicIndex - 1] : null;
const nextTopic = topicIndex < topics.length - 1 ? topics[topicIndex + 1] : null;
---

<BaseLayout
  title={`${topic.name} — OCR GCSE Computer Science`}
  description={`Exam practice questions and revision notes for OCR GCSE J277 ${topic.name}`}
>
  <Nav />

  <section class="px-4 py-10 sm:px-6 border-b border-white/8">
    <div class="mx-auto max-w-5xl">
      <div class="flex items-center gap-2 text-sm text-slate-400 mb-4">
        <a href="/revision" class="hover:text-white transition-colors">Revision</a>
        <span>›</span>
        <a href="/revision/ocr-gcse-computer-science" class="hover:text-white transition-colors">OCR GCSE</a>
        <span>›</span>
        <span class="text-white">{topic.name}</span>
      </div>

      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="text-xs font-bold text-cyan-400 mb-1">OCR GCSE J277 · Topic {topic.num}</div>
          <h1 class="text-4xl font-black text-white mb-2">{topic.name}</h1>
          <p class="text-slate-400">{questions.length} practice questions</p>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-10 sm:px-6">
    <div class="mx-auto max-w-5xl">

      <!-- Tab nav -->
      <div class="flex gap-2 mb-8 border-b border-white/10 pb-4">
        <a href="#questions" class="px-4 py-2 rounded-lg bg-cyan-500/20 text-cyan-400 border border-cyan-500/30 text-sm font-bold">
          📝 Questions ({questions.length})
        </a>
        {topicNotes && (
          <a href="#notes" class="px-4 py-2 rounded-lg bg-white/5 text-slate-400 border border-white/10 text-sm font-bold hover:text-white transition-colors">
            📚 Notes
          </a>
        )}
      </div>

      <!-- Questions -->
      <div id="questions" class="mb-16">
        <h2 class="text-2xl font-black text-white mb-6">Practice Questions</h2>
        <QuizTopic client:load {questions} topicName={topic.name} />
      </div>

      <!-- Notes -->
      {topicNotes && (
        <div id="notes" class="scroll-mt-20">
          <h2 class="text-2xl font-black text-white mb-6">Revision Notes</h2>
          <div class="space-y-6">
            {topicNotes.specPoints?.map((sp: any) => (
              <div class="rounded-xl border border-white/10 bg-white/5 p-6">
                <h3 class="text-lg font-bold text-white mb-4">{sp.title}</h3>
                {sp.examTip && (
                  <div class="mb-4 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-300">
                    ⭐ <strong>Exam tip:</strong> {sp.examTip}
                  </div>
                )}
                <div class="space-y-3">
                  {sp.sections?.map((s: any) => (
                    <div>
                      {s.type === 'text' && (
                        <div>
                          {s.heading && <h4 class="font-bold text-slate-200 mb-1">{s.heading}</h4>}
                          <p class="text-slate-400 text-sm" set:html={s.body} />
                        </div>
                      )}
                      {s.type === 'keyterm' && (
                        <div class="rounded-lg bg-cyan-500/10 border border-cyan-500/20 px-4 py-2">
                          <span class="font-bold text-cyan-400">{s.term}:</span>
                          <span class="text-slate-300 text-sm ml-2">{s.def}</span>
                        </div>
                      )}
                      {s.type === 'tip' && (
                        <div class="rounded-lg bg-green-500/10 border border-green-500/20 px-4 py-2 text-green-300 text-sm">
                          💡 {s.text}
                        </div>
                      )}
                      {s.type === 'mistake' && (
                        <div class="rounded-lg bg-red-500/10 border border-red-500/20 px-4 py-2 text-red-300 text-sm">
                          ⚠️ <strong>Common mistake:</strong> {s.text}
                        </div>
                      )}
                      {s.type === 'worked' && (
                        <div class="rounded-lg bg-white/5 border border-white/10 p-4">
                          <div class="text-xs font-bold text-slate-400 mb-2">{s.label}</div>
                          <pre class="text-sm text-green-300 overflow-x-auto whitespace-pre-wrap">{s.code}</pre>
                        </div>
                      )}
                      {s.type === 'table' && s.headers && (
                        <div class="overflow-x-auto">
                          <table class="w-full text-sm border-collapse">
                            <thead>
                              <tr>
                                {s.headers.map((h: string) => (
                                  <th class="text-left px-3 py-2 border border-white/10 bg-white/5 text-slate-300 font-bold">{h}</th>
                                ))}
                              </tr>
                            </thead>
                            <tbody>
                              {s.rows?.map((row: string[]) => (
                                <tr>
                                  {row.map((cell: string) => (
                                    <td class="px-3 py-2 border border-white/10 text-slate-400">{cell}</td>
                                  ))}
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Prev / Next navigation -->
      <div class="flex justify-between gap-4 mt-16 pt-8 border-t border-white/10">
        {prevTopic ? (
          <a href={`/revision/ocr-gcse/${prevTopic.id}`} class="rounded-xl border border-white/10 bg-white/5 px-5 py-3 hover:bg-white/10 transition-colors">
            <div class="text-xs text-slate-400 mb-1">← Previous</div>
            <div class="font-bold text-white text-sm">{prevTopic.name}</div>
          </a>
        ) : <div />}

        {nextTopic && (
          <a href={`/revision/ocr-gcse/${nextTopic.id}`} class="rounded-xl border border-white/10 bg-white/5 px-5 py-3 hover:bg-white/10 transition-colors text-right">
            <div class="text-xs text-slate-400 mb-1">Next →</div>
            <div class="font-bold text-white text-sm">{nextTopic.name}</div>
          </a>
        )}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
