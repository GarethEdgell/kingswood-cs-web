---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PythonQuest from '../../components/courses/PythonQuest.svelte';
import { PYTHON_WORLDS, getAllChallenges } from '../../data/pythonCourse';

const worldCount = PYTHON_WORLDS.length;
const challengeCount = getAllChallenges().length;
---

<BaseLayout
  title="Python Quest — Gamified OCR GCSE Python | Kingswood"
  description="Learn every Python skill you need for OCR GCSE Computer Science J277 through interactive coding challenges. Earn XP, level up, master the spec."
>
  <Nav />

  <!-- HERO -->
  <section class="relative overflow-hidden px-4 py-16 sm:px-6 sm:py-20 text-center">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 left-1/2 -translate-x-1/2 h-[500px] w-[700px] rounded-full opacity-20"
           style="background: radial-gradient(circle, #00d4ff 0%, #7c3aed 50%, transparent 70%)"></div>
    </div>
    <div class="relative mx-auto max-w-3xl">
      <div class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-semibold mb-6"
           style="border-color:rgba(0,212,255,0.4); background:rgba(0,212,255,0.08); color:#00d4ff">
        <span class="h-1.5 w-1.5 rounded-full animate-pulse" style="background:#00d4ff"></span>
        OCR GCSE J277 · Component 02
      </div>
      <h1 class="text-5xl sm:text-6xl font-black text-white mb-4 leading-none">
        Python <span style="background:linear-gradient(135deg,#00d4ff,#7c3aed);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Quest</span>
      </h1>
      <p class="text-lg text-slate-400 mb-6 max-w-2xl mx-auto">
        Master every programming skill on the OCR GCSE spec by writing real Python in your browser.
        {worldCount} worlds · {challengeCount} challenges · earn XP and level up.
      </p>
      <div class="flex flex-wrap justify-center gap-3 text-sm">
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">✅ Auto-checked</span>
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">🐍 Real Python</span>
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">📋 OCR-aligned</span>
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">💾 Saves progress</span>
      </div>
    </div>
  </section>

  <PythonQuest client:load />

  <Footer />
</BaseLayout>

<style>
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
  .animate-pulse { animation: pulse 2s ease-in-out infinite; }
</style>
