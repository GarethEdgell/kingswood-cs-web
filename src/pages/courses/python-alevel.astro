---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PythonQuest from '../../components/courses/PythonQuest.svelte';
import { PYTHON_ALEVEL_WORLDS, getAllALevelChallenges } from '../../data/pythonALevelCourse';

const worldCount = PYTHON_ALEVEL_WORLDS.length;
const challengeCount = getAllALevelChallenges().length;
---

<BaseLayout
  title="Python Quest: A Level — Gamified OCR A Level Python | Kingswood"
  description="Master the OCR A Level H446 algorithm and programming content in Python — recursion, searching, sorting, data structures, OOP and standard algorithms — through interactive coding challenges. Earn XP and level up."
>
  <Nav />

  <!-- HERO -->
  <section class="relative overflow-hidden px-4 py-16 sm:px-6 sm:py-20 text-center">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 left-1/2 -translate-x-1/2 h-[500px] w-[700px] rounded-full opacity-20"
           style="background: radial-gradient(circle, #7c3aed 0%, #00d4ff 50%, transparent 70%)"></div>
    </div>
    <div class="relative mx-auto max-w-3xl">
      <div class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-semibold mb-6"
           style="border-color:rgba(124,58,237,0.4); background:rgba(124,58,237,0.10); color:#a78bfa">
        <span class="h-1.5 w-1.5 rounded-full animate-pulse" style="background:#a78bfa"></span>
        OCR A Level H446 · Algorithms & Programming
      </div>
      <h1 class="text-5xl sm:text-6xl font-black text-white mb-4 leading-none">
        Python <span style="background:linear-gradient(135deg,#7c3aed,#00d4ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Quest</span>
        <span class="block text-2xl sm:text-3xl font-black mt-2 text-slate-300">A Level Edition</span>
      </h1>
      <p class="text-lg text-slate-400 mb-6 max-w-2xl mx-auto">
        Master the OCR A Level programming and algorithm content by writing real Python in your browser —
        recursion, searching, sorting, data structures, OOP and standard algorithms.
        {worldCount} worlds · {challengeCount} challenges · earn XP and level up.
      </p>
      <div class="flex flex-wrap justify-center gap-3 text-sm">
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">✅ Auto-checked</span>
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">🐍 Real Python</span>
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">📋 H446-aligned</span>
        <span class="rounded-lg bg-white/5 border border-white/10 px-3 py-1.5 text-slate-300">💾 Saves progress</span>
      </div>
    </div>
  </section>

  <PythonQuest
    client:load
    worlds={PYTHON_ALEVEL_WORLDS}
    storageKey="pyquest-alevel-progress"
    masteryNoun="the OCR A Level programming and algorithm content"
  />

  <Footer />
</BaseLayout>

<style>
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
  .animate-pulse { animation: pulse 2s ease-in-out infinite; }
</style>
