---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'OCR GCSE & A Level Computer Science, Digital Futures curriculum, and interactive learning tools for Kingswood School.',
  ogImage = '/og-default.png',
} = Astro.props;

const siteBase = Astro.site ?? new URL('https://kingswoodcomputerscience.com');
const canonicalUrl = new URL(Astro.url.pathname, siteBase);
const ogImageAbsolute = new URL(ogImage, siteBase).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Apply saved theme before render to avoid flash
      try {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') document.documentElement.classList.add('light');
      } catch(e) {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Kingswood Computer Science" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#00d4ff" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-[var(--bg-base)] text-slate-200 font-sans antialiased">
    <slot />
  </body>
</html>
