# Supabase (school project instance)
PUBLIC_SUPABASE_URL=your_supabase_url_here
PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Azure AD / Microsoft Entra
# Configure in Supabase dashboard: Auth > Providers > Azure
# No extra env vars needed beyond Supabase keys

# Teacher-mediated AI (Digital Futures assignments)
# AI_PROVIDER controls which backend the teacher AI runner uses:
#   stub      = no real AI, returns a labelled placeholder (default, no key/cost)
#   anthropic = call the Claude API (requires ANTHROPIC_API_KEY below)
AI_PROVIDER=stub
ANTHROPIC_API_KEY=
# Optional model override (default: claude-haiku-4-5-20251001 — cheap for bulk class runs)
AI_MODEL=
